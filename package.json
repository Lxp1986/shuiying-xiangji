{
  "name": "shuiying-xiangji",
  "version": "1.1.0",
  "description": "施工影像办公：水印、施工前后排版、导出 Word",
  "main": "desktop/main.js",
  "author": "Lxp1986",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "dev": "ELECTRON_RUN_AS_NODE= electron .",
    "web": "python3 -m http.server 5173",
    "prepare:web": "bash scripts/prepare-web.sh",
    "deploy:cf": "bash scripts/prepare-web.sh && wrangler pages deploy dist-web --project-name=shuiying-xiangji --commit-dirty=true",
    "db:init": "wrangler d1 execute shuiying-auth --remote --file=schema.sql",
    "pack": "ELECTRON_RUN_AS_NODE= electron-builder --dir",
    "dist": "ELECTRON_RUN_AS_NODE= electron-builder",
    "dist:mac": "ELECTRON_RUN_AS_NODE= electron-builder --mac",
    "dist:win": "ELECTRON_RUN_AS_NODE= electron-builder --win",
    "dist:linux": "ELECTRON_RUN_AS_NODE= electron-builder --linux"
  },
  "build": {
    "appId": "com.lxp1986.shuiyingxiangji",
    "productName": "施工影像办公",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "office.html",
      "index.html",
      "styles.css",
      "report.css",
      "app.js",
      "report.js",
      "icons/**/*",
      "desktop/**/*",
      "README.md"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icons/icon-1024.png",
      "target": ["dmg", "zip"],
      "darkModeSupport": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "icons/icon-512.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "linux": {
      "icon": "icons/icon-512.png",
      "target": ["AppImage", "deb"],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8"
  }
}
